# Server
PORT=8000

# Option B: Full ODBC connection string
# If this is set, it will be used instead of ODBC_DSN/ODBC_USER/ODBC_PASSWORD.
# ODBC_CONNECTION_STRING=DSN=TestData;UID=DBA;PWD=sql

# Optional API key for protecting /mcp.
# If set, Open WebUI must send Authorization: Bearer your-secret-key
# MCP_SERVER_API_KEY=your-secret-key

# CORS
# For local/dev, true is easiest.
# For production, set this to false and define CORS_ALLOWED_ORIGINS.
CORS_ALLOW_ALL=true

# Comma-separated origins when CORS_ALLOW_ALL=false
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Query row limits
DEFAULT_MAX_ROWS=100
HARD_MAX_ROWS=500